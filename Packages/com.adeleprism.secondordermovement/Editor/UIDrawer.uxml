<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" editor-extension-mode="True">
    <ui:Foldout text="Second Order Movement" value="true" toggle-on-label-click="true" name="DynamicMovementFolder" style="-unity-font-style: bold;">
        <ui:Slider label="Frequency" value="2.5" high-value="10" binding-path="frequency" name="Frequency" low-value="0.5" show-input-field="true" tooltip="How quickly the system moves, higher frequency means faster movements" style="-unity-font-style: normal;" />
        <ui:Slider label="Zeta" value="1" high-value="2" name="Zeta" binding-path="zeta" show-input-field="true" tooltip="How much energy is conserved over time. A Zeta value of 0 means no energy is lost, a value of 1 or higher means it doesnt overshoot." style="-unity-font-style: normal;" />
        <ui:Slider label="Response" value="1" high-value="10" name="Response" binding-path="response" low-value="-10" show-input-field="true" tooltip="The initial response of the system. Negative values leads to anticipating the motion, while positive values make the system accelerate immediately" style="-unity-font-style: normal;" />
        <ui:VisualElement name="graphContainer" style="flex-grow: 1; width: 100%; height: 300px; border-top-width: 3px; border-right-width: 3px; border-bottom-width: 3px; border-left-width: 3px; border-top-left-radius: 3px; border-top-right-radius: 3px; border-bottom-right-radius: 3px; border-bottom-left-radius: 3px; background-color: rgb(46, 46, 46); border-left-color: rgb(0, 0, 0); border-right-color: rgb(0, 0, 0); border-top-color: rgb(0, 0, 0); border-bottom-color: rgb(0, 0, 0); -unity-background-image-tint-color: rgb(0, 0, 0); opacity: 1; display: flex; visibility: visible; overflow: visible; background-image: none; margin-top: 2px; margin-bottom: 2px;" />
    </ui:Foldout>
</ui:UXML>
